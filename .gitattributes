# Default: treat text files as text and normalise to LF in the repo.
# Combined with `core.autocrlf=input` locally, this prevents Windows editors
# from reintroducing CRLF endings in commits.
* text=auto eol=lf

# Scripts run on Linux — force LF even when checked out on Windows.
*.sh   text eol=lf
*.bash text eol=lf

# Scripts that must keep CRLF for native Windows interpreters.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Known binary types — exempt from any text/EOL transformation.
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.bmp   binary
*.svgz  binary
*.webp  binary

*.zip   binary
